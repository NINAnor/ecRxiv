#### calculating scaled and non-truncated values for the indicators based on the dataset ####
for (i in 1:nrow(ANO.mount) ) {  #
tryCatch({
print(i)
print(paste(ANO.mount$ano_flate_id[i]))
print(paste(ANO.mount$ano_punkt_id[i]))
# Alien species evaluation
