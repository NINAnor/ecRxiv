library(sf)
library(terra)
library(dplyr)
library(lwgeom)
base_dir <- "C:/Users/kwaku.adjei/Downloads/fungiOutputs"
fungi_dirs <- list.dirs(base_dir, recursive = FALSE, full.names = TRUE)
fungi_dirs <- fungi_dirs[startsWith(basename(fungi_dirs), "fungiA")]
# Use one Bias RDS to define the region
bias_file <- list.files(
fungi_dirs[1],
pattern = "Bias.*\\.rds$|bias.*\\.rds$",
recursive = TRUE,
full.names = TRUE
)[1]
r <- readRDS(bias_file)
if (!inherits(r, "SpatRaster")) {
r <- terra::rast(r)
}
# Use first layer, e.g. mean, to define non-NA footprint
r_mean <- r[[1]]
# Non-NA raster footprint
footprint <- terra::as.polygons(!is.na(r_mean), dissolve = TRUE) |>
sf::st_as_sf() |>
sf::st_make_valid() |>
sf::st_collection_extract("POLYGON") |>
sf::st_union() |>
sf::st_as_sf()
# Keep CRS in km units; do NOT transform to 3857
set.seed(123)
# Oversample candidate centres inside non-NA footprint
pts <- sf::st_sample(
footprint,
size = 300,
type = "random"
)
pts_sf <- sf::st_sf(
candidate_id = seq_along(pts),
geometry = pts,
crs = sf::st_crs(footprint)
)
# Create candidate 10 km x 10 km blocks
# dist = 5 because CRS units are km
candidate_blocks <- sf::st_buffer(
pts_sf,
dist = 5,
endCapStyle = "SQUARE"
) |>
sf::st_make_valid()
# Count non-NA raster cells per candidate block
vals0 <- terra::extract(
r_mean,
terra::vect(candidate_blocks),
cells = TRUE
)
block_counts <- vals0 |>
dplyr::filter(!is.na(mean)) |>
dplyr::count(ID, name = "n_nonNA_cells") |>
dplyr::arrange(desc(n_nonNA_cells))
# Keep blocks with close to 100 cells
valid_ids <- block_counts |>
dplyr::filter(n_nonNA_cells >= 90) |>
dplyr::slice_head(n = 10) |>
dplyr::pull(ID)
valid_ids
# Keep blocks with close to 100 cells
valid_ids <- block_counts |>
dplyr::filter(n_nonNA_cells >= 100) |>
dplyr::slice_head(n = 10) |>
dplyr::pull(ID)
valid_ids
blocks <- candidate_blocks[valid_ids, ]
blocks$block_id <- paste0("block_", seq_len(nrow(blocks)))
# Check selected block counts
selected_counts <- block_counts |>
dplyr::filter(ID %in% valid_ids)
selected_counts
min_cells <- 100   # 100 may be too strict because edge alignment can give <100
all_results <- list()
for (fungi_dir in fungi_dirs) {
bias_files <- list.files(
fungi_dir,
pattern = "Bias.*\\.rds$|bias.*\\.rds$",
recursive = TRUE,
full.names = TRUE
)
if (length(bias_files) == 0) next
for (bias_file in bias_files) {
r <- readRDS(bias_file)
if (!inherits(r, "SpatRaster")) r <- terra::rast(r)
# Do NOT transform: raster CRS units are km
blocks_r <- candidate_blocks
value_col <- names(r)[1]
vals0 <- terra::extract(
r[[value_col]],
terra::vect(blocks_r),
cells = TRUE
)
block_counts <- vals0 |>
dplyr::filter(!is.na(.data[[value_col]])) |>
dplyr::count(ID, name = "n_nonNA") |>
dplyr::arrange(desc(n_nonNA))
valid_ids <- block_counts |>
dplyr::filter(n_nonNA >= min_cells) |>
dplyr::slice_head(n = 10) |>
dplyr::pull(ID)
if (length(valid_ids) < 10) {
warning(
"Only ", length(valid_ids),
" valid blocks found for ", basename(bias_file),
". Max cells = ", max(block_counts$n_nonNA, na.rm = TRUE)
)
next
}
blocks_use <- blocks_r[valid_ids, ]
blocks_use$block_id <- paste0("block_", seq_len(nrow(blocks_use)))
vals <- terra::extract(
r,
terra::vect(blocks_use),
cells = TRUE
)
vals <- vals |>
dplyr::mutate(
block_id = blocks_use$block_id[ID],
fungi_folder = basename(fungi_dir),
bias_file = basename(bias_file)
) |>
dplyr::filter(!is.na(.data[[value_col]])) |>
dplyr::select(
fungi_folder,
bias_file,
block_id,
cell,
dplyr::everything(),
-ID
)
all_results[[length(all_results) + 1]] <- vals
}
}
bias_values <- dplyr::bind_rows(all_results)
bias_values |>
dplyr::count(fungi_folder, bias_file, block_id, name = "n_cells")
anova_mod <- aov(mean ~ block_id, data = bias_values)
summary(anova_mod)
library(car)
leveneTest(
mean ~ block_id,
data = bias_values,
center = median
)
library(dplyr)
library(purrr)
set.seed(123)
n_perm <- 999
value_col <- "mean"
# Observed statistics
obs_stats <- bias_values |>
group_by(fungi_folder, bias_file, block_id) |>
summarise(
block_mean = mean(.data[[value_col]], na.rm = TRUE),
block_var  = var(.data[[value_col]], na.rm = TRUE),
.groups = "drop"
) |>
group_by(fungi_folder, bias_file) |>
summarise(
obs_mean_stat = var(block_mean, na.rm = TRUE),
obs_var_stat  = var(block_var, na.rm = TRUE),
.groups = "drop"
)
# Permutation function
perm_one <- function(dat, n_perm = 999, value_col = "mean") {
obs <- dat |>
group_by(block_id) |>
summarise(
block_mean = mean(.data[[value_col]], na.rm = TRUE),
block_var  = var(.data[[value_col]], na.rm = TRUE),
.groups = "drop"
)
obs_mean_stat <- var(obs$block_mean, na.rm = TRUE)
obs_var_stat  <- var(obs$block_var, na.rm = TRUE)
perm_stats <- replicate(n_perm, {
dat_perm <- dat |>
mutate(block_id_perm = sample(block_id))
tmp <- dat_perm |>
group_by(block_id_perm) |>
summarise(
block_mean = mean(.data[[value_col]], na.rm = TRUE),
block_var  = var(.data[[value_col]], na.rm = TRUE),
.groups = "drop"
)
c(
mean_stat = var(tmp$block_mean, na.rm = TRUE),
var_stat  = var(tmp$block_var, na.rm = TRUE)
)
})
perm_stats <- as.data.frame(t(perm_stats))
data.frame(
obs_mean_stat = obs_mean_stat,
p_mean = (sum(perm_stats$mean_stat >= obs_mean_stat) + 1) / (n_perm + 1),
obs_var_stat = obs_var_stat,
p_var = (sum(perm_stats$var_stat >= obs_var_stat) + 1) / (n_perm + 1)
)
}
# Run per fungi folder / bias file
perm_results <- bias_values |>
group_by(fungi_folder, bias_file) |>
group_modify(~ perm_one(.x, n_perm = n_perm, value_col = value_col)) |>
ungroup()
perm_results
library(sf)
library(terra)
library(dplyr)
library(tidyr)
library(lwgeom)
base_dir <- "C:/Users/kwaku.adjei/Downloads/fungiOutputs"
n_blocks  <- 10
min_cells <- 100
n_perm    <- 999
set.seed(123)
fungi_dirs <- list.dirs(base_dir, recursive = FALSE, full.names = TRUE)
fungi_dirs <- fungi_dirs[startsWith(basename(fungi_dirs), "fungiA")]
example_bias_file <- list.files(
fungi_dirs[1],
pattern = "Bias.*\\.rds$|bias.*\\.rds$",
recursive = TRUE,
full.names = TRUE
)[1]
r0 <- readRDS(example_bias_file)
if (!inherits(r0, "SpatRaster")) {
r0 <- terra::rast(r0)
}
value_col <- names(r0)[1]
r0_use <- r0[[value_col]]
footprint <- terra::as.polygons(!is.na(r0_use), dissolve = TRUE) |>
sf::st_as_sf() |>
sf::st_make_valid() |>
sf::st_collection_extract("POLYGON") |>
sf::st_union() |>
sf::st_as_sf()
pts <- sf::st_sample(
footprint,
size = 500,
type = "random"
)
pts_sf <- sf::st_sf(
candidate_id = seq_along(pts),
geometry = pts,
crs = sf::st_crs(footprint)
)
candidate_blocks <- sf::st_buffer(
pts_sf,
dist = 5,
endCapStyle = "SQUARE"
) |>
sf::st_make_valid()
vals0 <- terra::extract(
r0_use,
terra::vect(candidate_blocks),
cells = TRUE
)
block_counts <- vals0 |>
dplyr::filter(!is.na(.data[[value_col]])) |>
dplyr::count(ID, name = "n_nonNA") |>
dplyr::arrange(desc(n_nonNA))
valid_ids <- block_counts |>
dplyr::filter(n_nonNA >= min_cells) |>
dplyr::slice_head(n = n_blocks) |>
dplyr::pull(ID)
if (length(valid_ids) < n_blocks) {
stop("Fewer than 10 valid blocks found. Try reducing min_cells.")
}
blocks <- candidate_blocks[valid_ids, ]
blocks$block_id <- paste0("block_", seq_len(nrow(blocks)))
all_results <- list()
counter <- 1
for (fungi_dir in fungi_dirs) {
bias_files <- list.files(
fungi_dir,
pattern = "Bias.*\\.rds$|bias.*\\.rds$",
recursive = TRUE,
full.names = TRUE
)
if (length(bias_files) == 0) next
for (bias_file in bias_files) {
r <- readRDS(bias_file)
if (!inherits(r, "SpatRaster")) {
r <- terra::rast(r)
}
value_col <- names(r)[1]
r_use <- r[[value_col]]
vals <- terra::extract(
r_use,
terra::vect(blocks),
cells = TRUE
)
vals <- vals |>
dplyr::mutate(
fungi_folder = basename(fungi_dir),
bias_file = basename(bias_file),
block_id = blocks$block_id[ID]
) |>
dplyr::filter(!is.na(.data[[value_col]])) |>
dplyr::select(
fungi_folder,
bias_file,
block_id,
cell,
bias_value = all_of(value_col)
)
all_results[[counter]] <- vals
counter <- counter + 1
}
}
bias_values <- dplyr::bind_rows(all_results)
raster_block_summary <- bias_values |>
dplyr::group_by(fungi_folder, bias_file, block_id) |>
dplyr::summarise(
block_mean = mean(bias_value, na.rm = TRUE),
block_var  = var(bias_value, na.rm = TRUE),
n_cells = dplyr::n(),
.groups = "drop"
)
raster_block_summary
mean_mod <- aov(
block_mean ~ fungi_folder + block_id,
data = raster_block_summary
)
var_mod <- aov(
block_var ~ fungi_folder + block_id,
data = raster_block_summary
)
mean_anova <- summary(mean_mod)
var_anova  <- summary(var_mod)
obs_mean_F <- mean_anova[[1]]["fungi_folder", "F value"]
obs_var_F  <- var_anova[[1]]["fungi_folder", "F value"]
obs_mean_F
obs_var_F
mean_anova
var_anova
perm_F <- replicate(n_perm, {
perm_dat <- raster_block_summary |>
dplyr::group_by(block_id) |>
dplyr::mutate(fungi_perm = sample(fungi_folder)) |>
dplyr::ungroup()
mean_F <- summary(
aov(block_mean ~ fungi_perm + block_id, data = perm_dat)
)[[1]]["fungi_perm", "F value"]
var_F <- summary(
aov(block_var ~ fungi_perm + block_id, data = perm_dat)
)[[1]]["fungi_perm", "F value"]
c(
mean_F = mean_F,
var_F = var_F
)
})
perm_F <- as.data.frame(t(perm_F))
p_mean <- (sum(perm_F$mean_F >= obs_mean_F, na.rm = TRUE) + 1) /
(n_perm + 1)
p_var <- (sum(perm_F$var_F >= obs_var_F, na.rm = TRUE) + 1) /
(n_perm + 1)
p_mean
p_var
test_results <- data.frame(
test = c(
"Mean bias differs among fungi groups",
"Bias variance differs among fungi groups"
),
observed_F = c(obs_mean_F, obs_var_F),
permutation_p_value = c(p_mean, p_var),
n_permutations = n_perm
)
test_results
raster_block_summary
test_results
