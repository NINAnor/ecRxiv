b_region <- fixef(alien.re)$cond
vc_region <- vcov(alien.re)$cond
phi <- sigma(alien.re)
library(MASS)
eta_draws <- MASS::mvrnorm(
n = 10,
mu = b_region,
Sigma = vc_region
)
mu_draws <- plogis(eta_draws)
eta_draws
estimates_region <- do.call(
rbind,
lapply(seq_along(b_region), function(i) {
reg <- names(b_region)[i]
mu_i <- mu_draws[, i]
alien_res_sim <- rbeta(
n = 10,
shape1 = mu_i * phi,
shape2 = (1 - mu_i) * phi
)
data.frame(
region = reg,
draw = 1:10,
eta = eta_draws[, i],
mu = mu_i,
dispersion = phi,
alien_res_sim = alien_res_sim
)
})
)
estimates_region
alien.no_sim
## Norway
# Fixed-effect intercept and SE
b0 <- fixef(alien.no)$cond["(Intercept)"]
se_b0 <- sqrt(vcov(alien.no)$cond["(Intercept)", "(Intercept)"])
# Dispersion parameter (For glmmTMB this is usually on the response/positive scale via sigma() )
phi <- sigma(alien.no)
# draw estimates and backtransform from logit-scale
eta_draws <- rnorm(1000, mean = b0, sd = se_b0)
mu_draws  <- plogis(eta_draws)
# draw from beta distribution to consider the dispersion parameter
alien.no_sim <- rbeta(
n = 1000,
shape1 = mu_draws * phi,
shape2 = (1 - mu_draws) * phi
)
## regions
alien.no_sim
estimates_region <- do.call(
rbind,
lapply(seq_along(b_region), function(i) {
