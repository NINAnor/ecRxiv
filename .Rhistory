summary(mountain.ref.cov.val)
#### calculating scaled and non-truncated values for the indicators based on the dataset ####
# drop geometry
ANO.mountain <- ANO.mountain %>%
mutate(
X = st_coordinates(.)[, 1],
Y = st_coordinates(.)[, 2]
) %>%
st_drop_geometry()
for (i in 1:nrow(ANO.mountain) ) {  #
tryCatch({
print(i)
print(paste(ANO.mountain$ano_flate_id[i]))
print(paste(ANO.mountain$ano_punkt_id[i]))
#    ANO.mountain$Hovedoekosystem_sirkel[i]
#    ANO.mountain$Hovedoekosystem_rute[i]
# if the ANO.hovedtype exists in the mountain reference
if ( ANO.mountain$hovedtype_rute[i] %in% unique(sub("\\-.*", "", mountain.ref.cov.val$grunn)) ) {
# if there is any species present in current ANO point
if ( length(ANO.sp.ind[ANO.sp.ind$parentglobalid==as.character(ANO.mountain$globalid[i]),'Species']) > 0 ) {
# Nitrogen
dat <- ANO.sp.ind[ANO.sp.ind$parentglobalid==as.character(ANO.mountain$globalid[i]),c('art_dekning','Nitrogen')]
ANO.mountain[i,'richness'] <- nrow(dat)
dat <- dat[!is.na(dat$Nitrogen),]
if ( nrow(dat)>0 ) {
val <- sum(dat[,'art_dekning'] * dat[,'Nitrogen'],na.rm=T) / sum(dat[,'art_dekning'],na.rm=T)
# lower part of distribution
ref <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Nitrogen1' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'Rv']
lim <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Nitrogen1' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'Gv']
maxmin <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Nitrogen1' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'maxmin']
# normalisation
ANO.mountain[i,'Nitrogen1'] <- ec_normalise(variable = val, x0 = maxmin, x60 = lim, x100 = ref, fun = "linear")
# upper part of distribution
ref <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Nitrogen2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'Rv']
lim <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Nitrogen2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'Gv']
maxmin <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Nitrogen2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'maxmin']
# normalisation
ANO.mountain[i,'Nitrogen2'] <- ec_normalise(variable = val, x0 = maxmin, x60 = lim, x100 = ref, fun = "linear")
}
}
}
}, error=function(e){cat("ERROR :",conditionMessage(e), "\n")})
}
# generate overall Nitrogen indicator
ANO.mountain$Nitrogen <- ANO.mountain$Nitrogen1*ANO.mountain$Nitrogen2
ANO.mountain$Nitrogen1[ANO.mountain$Nitrogen1==1] <- NA
ANO.mountain$Nitrogen2[ANO.mountain$Nitrogen2==1] <- NA
# add geometry again
ANO.mountain <- ANO.mountain %>%
st_as_sf(coords = c("X", "Y"), crs = st_crs(ANO.geo))
## Fit ordered beta regression null-model with a random effect
# Norway
nitrogen.no <- glmmTMB(
Nitrogen ~ 1 + (1|ano_flate_id),
data = ANO.mountain,
family = ordbeta
)
nitrogen1.no <- glmmTMB(
Nitrogen1 ~ 1 + (1|ano_flate_id),
data = ANO.mountain[!is.na(ANO.mountain$Nitrogen1),],
family = ordbeta
)
nitrogen2.no <- glmmTMB(
Nitrogen2 ~ 1 + (1|ano_flate_id),
data = ANO.mountain[!is.na(ANO.mountain$Nitrogen2),],
family = ordbeta
)
summary(nitrogen.no)
summary(nitrogen1.no)
summary(nitrogen2.no)
# regions
nitrogen.re <- glmmTMB(
Nitrogen ~ 0 + region + (1|ano_flate_id),
data = ANO.mountain,
family = ordbeta
)
View(ANO.mountain)
ANO.mountain = st_join(ANO.mountain, regnor, left = TRUE, join = st_nearest_feature)
## Fit ordered beta regression null-model with a random effect
# Norway
nitrogen.no <- glmmTMB(
Nitrogen ~ 1 + (1|ano_flate_id),
data = ANO.mountain,
family = ordbeta
)
nitrogen1.no <- glmmTMB(
Nitrogen1 ~ 1 + (1|ano_flate_id),
data = ANO.mountain[!is.na(ANO.mountain$Nitrogen1),],
family = ordbeta
)
nitrogen2.no <- glmmTMB(
Nitrogen2 ~ 1 + (1|ano_flate_id),
data = ANO.mountain[!is.na(ANO.mountain$Nitrogen2),],
family = ordbeta
)
summary(nitrogen.no)
summary(nitrogen1.no)
summary(nitrogen2.no)
# regions
nitrogen.re <- glmmTMB(
Nitrogen ~ 0 + region + (1|ano_flate_id),
data = ANO.mountain,
family = ordbeta
)
nitrogen1.re <- glmmTMB(
Nitrogen1 ~ 0 + region + (1|ano_flate_id),
data = ANO.mountain[!is.na(ANO.mountain$Nitrogen1),],
family = ordbeta
)
nitrogen2.re <- glmmTMB(
Nitrogen2 ~ 0 + region + (1|ano_flate_id),
data = ANO.mountain[!is.na(ANO.mountain$Nitrogen2),],
family = ordbeta
)
summary(nitrogen.re)
summary(nitrogen1.re)
summary(nitrogen2.re)
NO_FUNI_002_table <- tibble(
Region = c("Norway", "Central Norway", "Eastern Norway", "Northern Norway", "Southern Norway", "Western Norway"),
indicator_value = c(plogis(summary(nitrogen.no)$coef$cond[,1]), plogis(summary(nitrogen.re)$coef$cond[,1])),
CI_upper = c(plogis(summary(nitrogen.no)$coef$cond[,1]+1.96*summary(nitrogen.no)$coef$cond[,2]), plogis(summary(nitrogen.re)$coef$cond[,1]+1.96*summary(nitrogen.re)$coef$cond[,2])),
CI_lower = as.numeric(plogis(summary(nitrogen.no)$coef$cond[,1]-1.96*summary(nitrogen.no)$coef$cond[,2]), plogis(summary(nitrogen.re)$coef$cond[,1]-1.96*summary(nitrogen.re)$coef$cond[,2])),
upper_indicator_value = c(plogis(summary(nitrogen2.no)$coef$cond[,1]), plogis(summary(nitrogen2.re)$coef$cond[,1])),
n_upper_indicator_value = c(summary(nitrogen2.no)$nobs,as.vector(table(nitrogen2.re$frame$region))),
lower_indicator_value = c(plogis(summary(nitrogen1.no)$coef$cond[,1]), plogis(summary(nitrogen1.re)$coef$cond[,1])),
n_lower_indicator_value = c(summary(nitrogen1.no)$nobs,as.vector(table(nitrogen1.re$frame$region)))
)
NO_FUNI_002_table
## Norway
# Fixed-effect intercept and SE
b0 <- fixef(nitrogen.no)$cond["(Intercept)"]
se_b0 <- sqrt(vcov(nitrogen.no)$cond["(Intercept)", "(Intercept)"])
# Dispersion parameter (For glmmTMB this is usually on the response/positive scale via sigma() )
phi <- sigma(nitrogen.no)
# draw estimates and backtransform from logit-scale
eta_draws <- rnorm(1000, mean = b0, sd = se_b0)
mu_draws  <- plogis(eta_draws)
# draw from beta distribution to consider the dispersion parameter
nitrogen.no_sim <- rbeta(
n = 1000,
shape1 = mu_draws * phi,
shape2 = (1 - mu_draws) * phi
)
## regions
b_re <- fixef(nitrogen.re)$cond
vc_re <- vcov(nitrogen.re)$cond
phi <- sigma(nitrogen.re)
eta_draws <- MASS::mvrnorm(
n = 1000,
mu = b_re,
Sigma = vc_re
)
mu_draws <- plogis(eta_draws)
nitrogen_re_sim <- do.call(
rbind,
lapply(seq_along(b_re), function(i) {
region <- names(b_re)[i]
mu_i <- mu_draws[, i]
sim <- rbeta(
n = 1000,
shape1 = mu_i * phi,
shape2 = (1 - mu_i) * phi
)
data.frame(
region = region,
#      draw = 1:10,
#      eta = eta_draws[, i],
#      mu = mu_i,
#      dispersion = phi,
sim = sim
)
})
)
nitrogen_re_sim$region <- sub("^region", "", nitrogen_re_sim$region)
nitrogen_re_sim
# combining nitrogen_no_sim and nitrogen_re_sim
NO_FUNI_002_sim <- rbind(data.frame(region = 'Norway', sim = nitrogen.no_sim), nitrogen_re_sim)
