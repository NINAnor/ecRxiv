colnames(NiN.mountain)[2:28] <- c(
'T14-C1','T14-C2','T3-C3C6','T3-C9C12',
'T3-C2C5','T3-C8C11','T3-C1a','T3-C1b',
'T3-C4','T3-C7','T3-C10','T3-C13',
'T3-C14','T7-C1','T7-C2','T7-C3',
'T7-C6','T7-C8',
'T7-C12','T7-C13C14','T7-C4','T7-C7C9','T7-C5','T7-C10',
'T22-C1C3a','T22-C1C3b','T22-C2C4'
)
#head(NiN.mountain)
# translating the abundance classes into %-cover
coverscale <- data.frame(orig=0:6,
cov=c(0,1/32,1/8,3/8,0.6,4/5,1)
)
NiN.mountain.cov <- NiN.mountain
colnames(NiN.mountain.cov)
for (i in 2:28) {
NiN.mountain.cov[,i] <- coverscale[,2][ match(NiN.mountain[,i], 0:6 ) ]
}
NiN.mountain.cov$sp <- as.factor(NiN.mountain.cov$sp)
# Data from cache
mountain.ref.cov<-readRDS(paste0(here::here(), "/data/cache/mountain.ref.cov.RDS"))
# every NiN-type is represented by one 'generalisert artsliste'
# some NiN-types are represented by two such species lists
# in some cases two NiN-types are represented by the same species list
#head(mountain.ref.cov[[1]])
mountain.ref.cov[[1]][0,]
# NiN-types where each type is represented by one species list (including when one species list represents two NiN-types), i.e. excluding types with a- and b-suffix
names(mountain.ref.cov[["Nitrogen"]])
x <- c(1:6,9:24,27)
# checking the actual NiN-types in the mountain lists
mountain.NiNtypes <- colnames(mountain.ref.cov[["Nitrogen"]])
mountain.NiNtypes[-x] <- substr(mountain.NiNtypes[-x], 1, nchar(mountain.NiNtypes[-x])-1)
mountain.NiNtypes
# 2 indicator-value indicators: Light, "Nitrogen"
indEll.n=2
# creating a table to hold:
# for every indicator: the 0.5 quantile (median), 0.025 quantile and  0.975 quantile for each NiN-type (3 metrics -> 3 columns per indicator), for Heat_requirement in alpine/arctic systems we do 0.05 quantile and  0.95 quantile and ignore the former as it is a one-sided indicator
# for every nature type (nrows)
tab <- matrix(ncol=3*indEll.n, nrow=25 ) # 25 basic ecosystem types
# coercing the values into the table
myQuantiles <- c(0.25, 0.5, 0.75)
for (i in 1:length(x) ) {
tab[i,1:3] <- quantile(as.matrix(mountain.ref.cov[["Light"]][,x[i]]),probs=myQuantiles,na.rm=T)
tab[i,4:6] <- quantile(as.matrix(mountain.ref.cov[["Nitrogen"]][,x[i]]),probs=myQuantiles,na.rm=T)
}
tab <- as.data.frame(tab)
tab$NiN <- NA
tab$NiN[1:length(x)] <- names(mountain.ref.cov[[1]])[x]
tab
# NiN-types represented by several species lists
mountain.NiNtypes2 <- mountain.NiNtypes[-x]
unique(mountain.NiNtypes2)
grep(pattern=unique(mountain.NiNtypes2)[1], x=mountain.NiNtypes) # finds columns in e.g. colnames(mountain.ref.cov[["Light"]]) that match the first NiN-type
for (i in 1:length(unique(mountain.NiNtypes2)) ) {
tab[length(x)+i,1:3] <- quantile(as.matrix(mountain.ref.cov[["Light"]][,grep(pattern=unique(mountain.NiNtypes2)[i], x=mountain.NiNtypes)]),probs=myQuantiles,na.rm=T)
tab[length(x)+i,4:6] <- quantile(as.matrix(mountain.ref.cov[["Nitrogen"]][,grep(pattern=unique(mountain.NiNtypes2)[i], x=mountain.NiNtypes)]),probs=myQuantiles,na.rm=T)
tab$NiN[length(x)+i] <- unique(mountain.NiNtypes2)[i]
}
tab
# when species lists represent several NiN-types
tab$NiN
tab <- rbind(tab,tab[c(3:6,18,20,23,25),])
tab$NiN[c(3:6,18,20,23,25,26:33)] <- c("T3-C3","T3-C9","T3-C2","T3-C8",
"T7-C13","T7-C7","T22-C2","T22-C1",
"T3-C6","T3-C12","T3-C5","T3-C11",                                                    "T7-C14","T7-C9","T22-C4","T22-C3"
)
tab
# making it a proper data frame
dim(tab)
round(tab[,1:6],digits=2)
colnames(tab) <- c("Light_q2.5","Light_q50","Light_q97.5",
"Nitrogen_q2.5","Nitrogen_q50","Nitrogen_q97.5",
"NiN")
summary(tab)
tab$NiN <- gsub("C", "C-", tab$NiN) # add extra hyphen after C for NiN-types
tab
# restructuring into separate indicators for lower (q2.5) and higher (q97.5) than reference value (=median, q50)
y.Light <- numeric(length=nrow(tab)*2)
y.Light[((1:dim(tab)[1])*2)-1] <- tab$Light_q2.5
y.Light[((1:dim(tab)[1])*2)] <- tab$Light_q97.5
y.Nitrogen <- numeric(length=nrow(tab)*2)
y.Nitrogen[((1:dim(tab)[1])*2)-1] <- tab$Nitrogen_q2.5
y.Nitrogen[((1:dim(tab)[1])*2)] <- tab$Nitrogen_q97.5
# creating final objects holding the reference and limit values for all indicators
# ref object for indicators
mountain.ref.cov.val <- data.frame( grunn=c(rep(rep(tab$NiN,each=2),indEll.n)),
county=rep('all',(nrow(tab)*2*indEll.n)),
region=rep('all',(nrow(tab)*2*indEll.n)),
Ind=c(rep(c('Light1','Light2'),nrow(tab)),
rep(c('Nitrogen1','Nitrogen2'),nrow(tab))
),
Rv=c(rep(tab$Light_q50,each=2),
rep(tab$Nitrogen_q50,each=2)
),
Gv=c(y.Light,y.Nitrogen),
maxmin=c(rep(c(1,7),nrow(tab)), # 7 levels of Light
rep(c(1,9),nrow(tab))  # 9 levels of nitrogen
)
)
mountain.ref.cov.val
mountain.ref.cov.val$grunn <- as.factor(mountain.ref.cov.val$grunn)
mountain.ref.cov.val$Ind <- as.factor(mountain.ref.cov.val$Ind)
summary(mountain.ref.cov.val)
#### calculating scaled and non-truncated values for the indicators based on the dataset ####
# drop geometry
ANO.mountain <- ANO.mountain %>%
mutate(
X = st_coordinates(.)[, 1],
Y = st_coordinates(.)[, 2]
) %>%
st_drop_geometry()
for (i in 1:nrow(ANO.mountain) ) {  #
tryCatch({
print(i)
print(paste(ANO.mountain$ano_flate_id[i]))
print(paste(ANO.mountain$ano_punkt_id[i]))
#    ANO.mountain$Hovedoekosystem_sirkel[i]
#    ANO.mountain$Hovedoekosystem_rute[i]
# if the ANO.hovedtype exists in the mountain reference
if ( ANO.mountain$hovedtype_rute[i] %in% unique(sub("\\-.*", "", mountain.ref.cov.val$grunn)) ) {
# if there is any species present in current ANO point
if ( length(ANO.sp.ind[ANO.sp.ind$parentglobalid==as.character(ANO.mountain$globalid[i]),'Species']) > 0 ) {
# light
dat <- ANO.sp.ind[ANO.sp.ind$parentglobalid==as.character(ANO.mountain$globalid[i]),c('art_dekning','Light')]
ANO.mountain[i,'richness'] <- nrow(dat)
dat <- dat[!is.na(dat$Light),]
if ( nrow(dat)>0 ) {
val <- sum(dat[,'art_dekning'] * dat[,'Light'],na.rm=T) / sum(dat[,'art_dekning'],na.rm=T)
# lower part of distribution
ref <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Light1' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'Rv']
lim <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Light1' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'Gv']
maxmin <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Light1' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'maxmin']
# normalisation
ANO.mountain[i,'Light1'] <- ec_normalise(variable = val, x0 = maxmin, x60 = lim, x100 = ref, fun = "linear")
# upper part of distribution
ref <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Light2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'Rv']
lim <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Light2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'Gv']
maxmin <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Light2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'maxmin']
# normalisation
ANO.mountain[i,'Light2'] <- ec_normalise(variable = val, x0 = maxmin, x60 = lim, x100 = ref, fun = "linear")
}
}
}
}, error=function(e){cat("ERROR :",conditionMessage(e), "\n")})
}
# generate overall light indicator
ANO.mountain$Light <- ANO.mountain$Light1*ANO.mountain$Light2
ANO.mountain$Light1[ANO.mountain$Light1==1] <- NA
ANO.mountain$Light2[ANO.mountain$Light2==1] <- NA
# add geometry again
ANO.mountain <- ANO.mountain %>%
st_as_sf(coords = c("X", "Y"), crs = st_crs(ANO.geo))
## Fit ordered beta regression null-model with a random effect
# Norway
light.no <- glmmTMB(
Light ~ 1 + (1|ano_flate_id),
data = ANO.mountain,
family = ordbeta
)
light1.no <- glmmTMB(
Light1 ~ 1 + (1|ano_flate_id),
data = ANO.mountain[!is.na(ANO.mountain$Light1),],
family = ordbeta
)
light2.no <- glmmTMB(
Light2 ~ 1 + (1|ano_flate_id),
data = ANO.mountain[!is.na(ANO.mountain$Light2),],
family = ordbeta
)
summary(light.no)
summary(light1.no)
summary(light2.no)
# regions
light.re <- glmmTMB(
Light ~ 0 + region + (1|ano_flate_id),
data = ANO.mountain,
family = ordbeta
)
light1.re <- glmmTMB(
Light1 ~ 0 + region + (1|ano_flate_id),
data = ANO.mountain[!is.na(ANO.mountain$Light1),],
family = ordbeta
)
light2.re <- glmmTMB(
Light2 ~ 0 + region + (1|ano_flate_id),
data = ANO.mountain[!is.na(ANO.mountain$Light2),],
family = ordbeta
)
summary(light.re)
summary(light1.re)
summary(light2.re)
NO_FULI_002_table <- tibble(
Region = c("Norway", "Central Norway", "Eastern Norway", "Northern Norway", "Southern Norway", "Western Norway"),
indicator_value = c(plogis(summary(light.no)$coef$cond[,1]), plogis(summary(light.re)$coef$cond[,1])),
CI_upper = c(plogis(summary(light.no)$coef$cond[,1]+1.96*summary(light.no)$coef$cond[,2]), plogis(summary(light.re)$coef$cond[,1]+1.96*summary(light.re)$coef$cond[,2])),
CI_lower = as.numeric(plogis(summary(light.no)$coef$cond[,1]-1.96*summary(light.no)$coef$cond[,2]), plogis(summary(light.re)$coef$cond[,1]-1.96*summary(light.re)$coef$cond[,2])),
upper_indicator_value = c(plogis(summary(light2.no)$coef$cond[,1]), plogis(summary(light2.re)$coef$cond[,1])),
n_upper_indicator_value = c(summary(light2.no)$nobs,as.vector(table(light2.re$frame$region))),
lower_indicator_value = c(plogis(summary(light1.no)$coef$cond[,1]), plogis(summary(light1.re)$coef$cond[,1])),
n_lower_indicator_value = c(summary(light1.no)$nobs,as.vector(table(light1.re$frame$region)))
)
NO_FULI_002_table
NO_FULI_002_table
