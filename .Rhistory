#### calculating scaled and non-truncated values for the indicators based on the dataset ####
# drop geometry
ANO.mountain <- ANO.mountain %>%
mutate(
X = st_coordinates(.)[, 1],
Y = st_coordinates(.)[, 2]
) %>%
st_drop_geometry()
for (i in 1:nrow(ANO.mountain) ) {  #
tryCatch({
print(i)
print(paste(ANO.mountain$ano_flate_id[i]))
print(paste(ANO.mountain$ano_punkt_id[i]))
#    ANO.mountain$Hovedoekosystem_sirkel[i]
#    ANO.mountain$Hovedoekosystem_rute[i]
# if the ANO.hovedtype exists in the mountain reference
if ( ANO.mountain$hovedtype_rute[i] %in% unique(sub("\\-.*", "", mountain.ref.cov.val$grunn)) ) {
# if there is any species present in current ANO point
if ( length(ANO.sp.ind[ANO.sp.ind$parentglobalid==as.character(ANO.mountain$globalid[i]),'Species']) > 0 ) {
#Heat requirement overhang
dat <- ANO.sp.ind[ANO.sp.ind$parentglobalid==as.character(ANO.mountain$globalid[i]),c('art_dekning','Heat_requirement')]
results.ANO[['original']][i,'richness'] <- nrow(dat)
dat <- dat[!is.na(dat$Heat_requirement) & dat$art_dekning>0,]
if ( nrow(dat)>0 ) {
dat$art_dekning <- dat$art_dekning/sum(dat$art_dekning) # scaling to total cover of 100%
abun.cumsums <- abun.sums <- data.frame(Heat_requirement=rev(1:13),cumsum=NA)
dat <- dat %>% add_row(Heat_requirement=1:13, art_dekning =rep(0,13))
abun.sums[,2] <- rev(with(dat,tapply(art_dekning,Heat_requirement,sum)))
abun.cumsums[,2] <- cumsum(abun.sums[,2])
val <- abun.cumsums[11,2]
# coercing val into the ANO.mountain dataframe
ANO.mountain[i,'Heat_requirement_raw'] <- val
# upper part of distribution
ref <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Heat_requirement2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'Rv']
lim <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Heat_requirement2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'Gv']
maxmin <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Heat_requirement2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'maxmin']
# normalisation
ANO.mountain[i,'Heat_requirement'] <- ec_normalise(variable = val, x0 = maxmin, x60 = lim, x100 = ref, fun = "linear")
}
}
}
}, error=function(e){cat("ERROR :",conditionMessage(e), "\n")})
}
#### calculating scaled and non-truncated values for the indicators based on the dataset ####
# drop geometry
ANO.mountain <- ANO.mountain %>%
mutate(
X = st_coordinates(.)[, 1],
Y = st_coordinates(.)[, 2]
) %>%
st_drop_geometry()
ANO.mountain <- ANO.mountain %>%
st_as_sf(coords = c("X", "Y"), crs = st_crs(ANO.geo))
#### calculating scaled and non-truncated values for the indicators based on the dataset ####
# drop geometry
ANO.mountain <- ANO.mountain %>%
mutate(
X = st_coordinates(.)[, 1],
Y = st_coordinates(.)[, 2]
) %>%
st_drop_geometry()
for (i in 1:nrow(ANO.mountain) ) {  #
tryCatch({
print(i)
print(paste(ANO.mountain$ano_flate_id[i]))
print(paste(ANO.mountain$ano_punkt_id[i]))
#    ANO.mountain$Hovedoekosystem_sirkel[i]
#    ANO.mountain$Hovedoekosystem_rute[i]
# if the ANO.hovedtype exists in the mountain reference
if ( ANO.mountain$hovedtype_rute[i] %in% unique(sub("\\-.*", "", mountain.ref.cov.val$grunn)) ) {
# if there is any species present in current ANO point
if ( length(ANO.sp.ind[ANO.sp.ind$parentglobalid==as.character(ANO.mountain$globalid[i]),'Species']) > 0 ) {
#Heat requirement overhang
dat <- ANO.sp.ind[ANO.sp.ind$parentglobalid==as.character(ANO.mountain$globalid[i]),c('art_dekning','Heat_requirement')]
ANO.mountain[i,'richness'] <- nrow(dat)
dat <- dat[!is.na(dat$Heat_requirement) & dat$art_dekning>0,]
if ( nrow(dat)>0 ) {
dat$art_dekning <- dat$art_dekning/sum(dat$art_dekning) # scaling to total cover of 100%
abun.cumsums <- abun.sums <- data.frame(Heat_requirement=rev(1:13),cumsum=NA)
dat <- dat %>% add_row(Heat_requirement=1:13, art_dekning =rep(0,13))
abun.sums[,2] <- rev(with(dat,tapply(art_dekning,Heat_requirement,sum)))
abun.cumsums[,2] <- cumsum(abun.sums[,2])
val <- abun.cumsums[11,2]
# coercing val into the ANO.mountain dataframe
ANO.mountain[i,'Heat_requirement_raw'] <- val
# upper part of distribution
ref <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Heat_requirement2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'Rv']
lim <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Heat_requirement2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'Gv']
maxmin <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Heat_requirement2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'maxmin']
# normalisation
ANO.mountain[i,'Heat_requirement'] <- ec_normalise(variable = val, x0 = maxmin, x60 = lim, x100 = ref, fun = "linear")
}
}
}
}, error=function(e){cat("ERROR :",conditionMessage(e), "\n")})
}
# add geometry again
ANO.mountain <- ANO.mountain %>%
st_as_sf(coords = c("X", "Y"), crs = st_crs(ANO.geo))
## Fit ordered beta regression null-model with a random effect
# Norway
heat_requirement.no <- glmmTMB(
Heat_requirement ~ 1 + (1|ano_flate_id),
data = ANO.mountain,
family = ordbeta
)
summary(heat_requirement.no)
# regions
heat_requirement.re <- glmmTMB(
Heat_requirement ~ 0 + region + (1|ano_flate_id),
data = ANO.mountain,
family = ordbeta
)
summary(heat_requirement.re)
NO_FUHR_002_table <- tibble(
Region = c("Norway", "Central Norway", "Eastern Norway", "Northern Norway", "Southern Norway", "Western Norway"),
indicator_value = c(plogis(summary(light.no)$coef$cond[,1]), plogis(summary(light.re)$coef$cond[,1])),
CI_upper = c(plogis(summary(light.no)$coef$cond[,1]+1.96*summary(light.no)$coef$cond[,2]), plogis(summary(light.re)$coef$cond[,1]+1.96*summary(light.re)$coef$cond[,2])),
CI_lower = as.numeric(plogis(summary(light.no)$coef$cond[,1]-1.96*summary(light.no)$coef$cond[,2]), plogis(summary(light.re)$coef$cond[,1]-1.96*summary(light.re)$coef$cond[,2]))
)
NO_FUHR_002_table <- tibble(
Region = c("Norway", "Central Norway", "Eastern Norway", "Northern Norway", "Southern Norway", "Western Norway"),
indicator_value = c(plogis(summary(heat_requirement.no)$coef$cond[,1]), plogis(summary(heat_requirement.re)$coef$cond[,1])),
CI_upper = c(plogis(summary(heat_requirement.no)$coef$cond[,1]+1.96*summary(heat_requirement.no)$coef$cond[,2]), plogis(summary(heat_requirement.re)$coef$cond[,1]+1.96*summary(heat_requirement.re)$coef$cond[,2])),
CI_lower = as.numeric(plogis(summary(heat_requirement.no)$coef$cond[,1]-1.96*summary(heat_requirement.no)$coef$cond[,2]), plogis(summary(heat_requirement.re)$coef$cond[,1]-1.96*summary(heat_requirement.re)$coef$cond[,2]))
)
NO_FUHR_002_table
## Norway
# Fixed-effect intercept and SE
b0 <- fixef(heat_requirement.no)$cond["(Intercept)"]
se_b0 <- sqrt(vcov(heat_requirement.no)$cond["(Intercept)", "(Intercept)"])
# Dispersion parameter (For glmmTMB this is usually on the response/positive scale via sigma() )
phi <- sigma(heat_requirement.no)
# draw estimates and backtransform from logit-scale
eta_draws <- rnorm(1000, mean = b0, sd = se_b0)
mu_draws  <- plogis(eta_draws)
# draw from beta distribution to consider the dispersion parameter
heat_requirement.no_sim <- rbeta(
n = 1000,
shape1 = mu_draws * phi,
shape2 = (1 - mu_draws) * phi
)
## regions
b_re <- fixef(heat_requirement.re)$cond
vc_re <- vcov(heat_requirement.re)$cond
phi <- sigma(heat_requirement.re)
eta_draws <- MASS::mvrnorm(
n = 1000,
mu = b_re,
Sigma = vc_re
)
mu_draws <- plogis(eta_draws)
heat_requirement_re_sim <- do.call(
rbind,
lapply(seq_along(b_re), function(i) {
region <- names(b_re)[i]
mu_i <- mu_draws[, i]
sim <- rbeta(
n = 1000,
shape1 = mu_i * phi,
shape2 = (1 - mu_i) * phi
)
data.frame(
region = region,
#      draw = 1:10,
#      eta = eta_draws[, i],
#      mu = mu_i,
#      dispersion = phi,
sim = sim
)
})
)
heat_requirement_re_sim$region <- sub("^region", "", heat_requirement_re_sim$region)
heat_requirement_re_sim
# combining heat_requirement_no_sim and heat_requirement_re_sim
NO_FUHR_002_sim <- rbind(data.frame(region = 'Norway', sim = heat_requirement.no_sim), heat_requirement_re_sim)
