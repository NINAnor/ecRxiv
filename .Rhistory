unique(ANO.mount$hovedoekosystem_250m2) # major ecosystem types in circle data
#### creating dataframe to hold the results for wetlands ####
results.ANO.alien <- list()
results.ANO.alien[['original']] <- ANO.mount
# drop geometry
st_geometry(results.ANO.alien[['original']]) <- NULL
results.ANO.alien[['original']]
# add column for the indicator
results.ANO.alien[['original']][,'alien'] <- NA
results.ANO.alien[['original']][,'alien'] <- as.numeric(results.ANO.alien[['original']][,'alien'])
summary(results.ANO.alien[['original']])
results.ANO.alien[['original']]$globalid <- as.factor(results.ANO.alien[['original']]$globalid)
results.ANO.alien[['original']]$ano_flate_id <- as.factor(results.ANO.alien[['original']]$ano_flate_id)
results.ANO.alien[['original']]$ano_punkt_id <- as.factor(results.ANO.alien[['original']]$ano_punkt_id)
results.ANO.alien[['original']]$hovedoekosystem_250m2 <- as.factor(results.ANO.alien[['original']]$hovedoekosystem_250m2)
# roll out
results.ANO.alien[['scaled']] <- results.ANO.alien[['original']]
#### calculating scaled and non-truncated values for the indicators based on the dataset ####
for (i in 1:nrow(ANO.mount) ) {  #
tryCatch({
print(i)
print(paste(ANO.mount$ano_flate_id[i]))
print(paste(ANO.mount$ano_punkt_id[i]))
# Alien species evaluation
val <- ANO.mount$fremmedarter_total_dekning[i]
if ( !is.na(val) ) {
# scaling thresholds
ref <- 0
lim <- 5
maxmin <- 50
# coercing x into results.ANO dataframe
results.ANO.alien[['scaled']][i,'alien'] <- scal()
results.ANO.alien[['original']][i,'alien'] <- val
}
}, error=function(e){cat("ERROR :",conditionMessage(e), "\n")})
}
#saveRDS(results.ANO.alien, paste0(here::here(),"/data/cache/results.ANO.alien.RDS"))
res.ANO.alien <- results.ANO.alien[['scaled']]
res.ANO.alien$alien_orig <- res.ANO.alien$fremmedarter_total_dekning
View(res.ANO.alien)
