b_region <- fixef(alien.re)$cond
vc_region <- vcov(alien.re)$cond
phi <- sigma(alien.re)
set.seed(123)
eta_draws <- MASS::mvrnorm(
n = 10,
mu = b_region,
Sigma = vc_region
)
mu_draws <- plogis(eta_draws)
estimates_region <- do.call(
rbind,
lapply(seq_along(b_region), function(i) {
reg <- names(b_region)[i]
mu_i <- mu_draws[, i]
alien_res_sim <- rbeta(
n = 10,
shape1 = mu_i * phi,
shape2 = (1 - mu_i) * phi
)
data.frame(
region = reg,
draw = 1:10,
eta = eta_draws[, i],
mu = mu_i,
dispersion = phi,
alien_res_sim = alien_res_sim
)
})
)
estimates_region$region <- sub("^region", "", estimates_region$region)
estimates_region
