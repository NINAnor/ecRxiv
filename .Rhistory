# normalisation
ANO.mountain[i,'Light1'] <- ec_normalise(variable = val, x0 = maxmin, x60 = lim, x100 = ref, fun = "linear")
# upper part of distribution
ref <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Light2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'Rv']
lim <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Light2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'Gv']
maxmin <- mountain.ref.cov.val[mountain.ref.cov.val$Ind=='Light2' & mountain.ref.cov.val$grunn==as.character(ANO.mountain[i,"kartleggingsenhet_1m2"]),'maxmin']
# normalisation
ANO.mountain[i,'Light2'] <- ec_normalise(variable = val, x0 = maxmin, x60 = lim, x100 = ref, fun = "linear")
}
}
}
}, error=function(e){cat("ERROR :",conditionMessage(e), "\n")})
}
# generate overall light indicator
ANO.mountain$Light <- ANO.mountain$Light1*ANO.mountain$Light2
ANO.mountain$Light1[ANO.mountain$Light1==1] <- NA
ANO.mountain$Light2[ANO.mountain$Light2==1] <- NA
# add geometry again
ANO.mountain <- ANO.mountain %>%
st_as_sf(coords = c("X", "Y"), crs = st_crs(ANO.geo))
## Fit ordered beta regression null-model with a random effect
# Norway
light.no <- glmmTMB(
Light ~ 1 + (1|ano_flate_id),
data = ANO.mountain,
family = ordbeta
)
light1.no <- glmmTMB(
Light1 ~ 1 + (1|ano_flate_id),
data = ANO.mountain[!is.na(ANO.mountain$Light1),],
family = ordbeta
)
light2.no <- glmmTMB(
Light2 ~ 1 + (1|ano_flate_id),
data = ANO.mountain[!is.na(ANO.mountain$Light2),],
family = ordbeta
)
summary(light.no)
summary(light1.no)
summary(light2.no)
# regions
light.re <- glmmTMB(
Light ~ 0 + region + (1|ano_flate_id),
data = ANO.mountain,
family = ordbeta
)
light1.re <- glmmTMB(
Light1 ~ 0 + region + (1|ano_flate_id),
data = ANO.mountain[!is.na(ANO.mountain$Light1),],
family = ordbeta
)
light2.re <- glmmTMB(
Light2 ~ 0 + region + (1|ano_flate_id),
data = ANO.mountain[!is.na(ANO.mountain$Light2),],
family = ordbeta
)
summary(light.re)
summary(light1.re)
summary(light2.re)
NO_FULI_002_table <- tibble(
Region = c("Norway", "Central Norway", "Eastern Norway", "Northern Norway", "Southern Norway", "Western Norway"),
indicator_value = c(plogis(summary(light.no)$coef$cond[,1]), plogis(summary(light.re)$coef$cond[,1])),
CI_upper = c(plogis(summary(light.no)$coef$cond[,1]+1.96*summary(light.no)$coef$cond[,2]), plogis(summary(light.re)$coef$cond[,1]+1.96*summary(light.re)$coef$cond[,2])),
CI_lower = as.numeric(plogis(summary(light.no)$coef$cond[,1]-1.96*summary(light.no)$coef$cond[,2]), plogis(summary(light.re)$coef$cond[,1]-1.96*summary(light.re)$coef$cond[,2])),
upper_indicator_value = c(plogis(summary(light2.no)$coef$cond[,1]), plogis(summary(light2.re)$coef$cond[,1])),
n_upper_indicator_value = c(summary(light2.no)$nobs,as.vector(table(light2.re$frame$region))),
lower_indicator_value = c(plogis(summary(light1.no)$coef$cond[,1]), plogis(summary(light1.re)$coef$cond[,1])),
n_lower_indicator_value = c(summary(light1.no)$nobs,as.vector(table(light1.re$frame$region)))
)
NO_FULI_002_table
## Norway
# Fixed-effect intercept and SE
b0 <- fixef(light.no)$cond["(Intercept)"]
se_b0 <- sqrt(vcov(light.no)$cond["(Intercept)", "(Intercept)"])
# Dispersion parameter (For glmmTMB this is usually on the response/positive scale via sigma() )
phi <- sigma(light.no)
# draw estimates and backtransform from logit-scale
eta_draws <- rnorm(1000, mean = b0, sd = se_b0)
mu_draws  <- plogis(eta_draws)
# draw from beta distribution to consider the dispersion parameter
light.no_sim <- rbeta(
n = 1000,
shape1 = mu_draws * phi,
shape2 = (1 - mu_draws) * phi
)
## regions
b_re <- fixef(light.re)$cond
vc_re <- vcov(light.re)$cond
phi <- sigma(light.re)
eta_draws <- MASS::mvrnorm(
n = 1000,
mu = b_re,
Sigma = vc_re
)
mu_draws <- plogis(eta_draws)
light_re_sim <- do.call(
rbind,
lapply(seq_along(b_re), function(i) {
region <- names(b_re)[i]
mu_i <- mu_draws[, i]
sim <- rbeta(
n = 1000,
shape1 = mu_i * phi,
shape2 = (1 - mu_i) * phi
)
data.frame(
region = region,
#      draw = 1:10,
#      eta = eta_draws[, i],
#      mu = mu_i,
#      dispersion = phi,
sim = sim
)
})
)
light_re_sim$region <- sub("^region", "", light_re_sim$region)
light_re_sim
# combining light_no_sim and light_re_sim
NO_FULI_002_sim <- rbind(data.frame(region = 'Norway', sim = light.no_sim), light_re_sim)
