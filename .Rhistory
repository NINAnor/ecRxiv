## Norway
# Fixed-effect intercept and SE
b0 <- fixef(alien.no)$cond["(Intercept)"]
se_b0 <- sqrt(vcov(alien.no)$cond["(Intercept)", "(Intercept)"])
# Dispersion parameter (For glmmTMB this is usually on the response/positive scale via sigma() )
phi <- sigma(alien.no)
# draw estimates and backtransform from logit-scale
eta_draws <- rnorm(1000, mean = b0, sd = se_b0)
mu_draws  <- plogis(eta_draws)
# draw from beta distribution to consider the dispersion parameter
alien.no_sim <- rbeta(
n = 1000,
shape1 = mu_draws * phi,
shape2 = (1 - mu_draws) * phi
)
## regions
library(MASS)
b_re <- fixef(alien.re)$cond
vc_re <- vcov(alien.re)$cond
phi <- sigma(alien.re)
eta_draws <- MASS::mvrnorm(
n = 1000,
mu = b_re,
Sigma = vc_re
)
mu_draws <- plogis(eta_draws)
estimates_re <- do.call(
rbind,
lapply(seq_along(b_re), function(i) {
region <- names(b_re)[i]
mu_i <- mu_draws[, i]
alien_re_sim <- rbeta(
n = 1000,
shape1 = mu_i * phi,
shape2 = (1 - mu_i) * phi
)
data.frame(
region = region,
#      draw = 1:10,
#      eta = eta_draws[, i],
#      mu = mu_i,
#      dispersion = phi,
alien_re_sim = alien_re_sim
)
})
)
estimates_region$region <- sub("^region", "", estimates_region$region)
estimates_region
estimates_re
View(estimates_region)
alien_re_sim <- do.call(
rbind,
lapply(seq_along(b_re), function(i) {
region <- names(b_re)[i]
mu_i <- mu_draws[, i]
sim <- rbeta(
n = 1000,
shape1 = mu_i * phi,
shape2 = (1 - mu_i) * phi
)
data.frame(
region = region,
#      draw = 1:10,
#      eta = eta_draws[, i],
#      mu = mu_i,
#      dispersion = phi,
sim = sim
)
})
)
alien_re_sim$region <- sub("^region", "", alien_re_sim$region)
alien_re_sim
View(alien_re_sim)
alien.no_sim
NO_ALIE_002_sim <- rbind(data.frame(region = 'Norway', sim = alien.no_sim), alien_re_sim)
