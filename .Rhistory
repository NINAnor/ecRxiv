library(knitr)
library(tidyverse)
library(kableExtra)
library(here)
library(anybadger)
library(yaml)
library(tibble)
library(conflicted)
library(sf)
library(ecTools)
library(glmmTMB)
# weird workarounds for cache issues
conflicts_prefer(dplyr::filter)
conflicts_prefer(dplyr::lag)
conflicts_prefer(dplyr::select)
pull<-dplyr::pull
knitr::opts_chunk$set(echo = TRUE)
#| echo: false
#| cache: false
source(here::here("_common.R"))
#Sys.setlocale("LC_ALL", "no_NB.utf8") #works with æøå or use "Norwegian"
ANO.geo <- st_read("P:/41201785_okologisk_tilstand_2022_2023/data/ANO/naturovervaking_eksport.gdb",
layer="ANO_SurveyPoint", quiet = T)
#Sys.setlocale("LC_ALL", "no_NB.utf8") #works with æøå or use "Norwegian"
ANO.geo <- st_read("P:/41201785_okologisk_tilstand_2022_2023/data/ANO/naturovervaking_eksport.gdb",
layer="ANO_SurveyPoint", quiet = T)
#head(ANO.geo)
## choose mountain ecosystems and years 2020-2024.
ANO.mount <- ANO.geo %>%
filter(hovedoekosystem_250m2 == 'fjell') %>%
filter(aar %in% 2020:2024)
#head(ANO.mount)
## check that every point is present only once
#length(levels(as.factor(ANO.mount$ano_flate_id)))
#length(levels(as.factor(ANO.mount$ano_punkt_id)))
#summary(as.factor(ANO.mount$ano_punkt_id))
# there's many double presences, probably some wrong registrations of point numbers,
## add region information
nor <- st_read(here::here("data/outlineOfNorway_EPSG25833.shp"),
quiet = T)%>%
st_as_sf() %>%
st_transform(crs = st_crs(ANO.mount))
reg <- st_read(here::here("data/regions.shp"),
quiet = T) %>%
st_as_sf() %>%
st_transform(crs = st_crs(ANO.mount))
# change region names to something R-friendly
# reg$region
reg$region <- c("Northern.Norway","Central.Norway","Eastern.Norway","Western.Norway","Southern.Norway")
regnor <- st_intersection(reg,nor)
ANO.mount = st_join(ANO.mount, regnor, left = TRUE, join = st_nearest_feature)
#| fig-cap: 'Normalisation function (piecewise linear)'
temp <- tibble(
variable = 0:100
)
temp <- temp %>% mutate(indicator = ec_normalise(variable = variable,
x0 = 50,
x60 = 5,
x100 = 0,
fun = "linear")
)
temp |>
ggplot() +
geom_line(aes(x = variable,
y = indicator))
## Fit ordered beta regression null-model with a random effect
# Norway
alien.no <- glmmTMB(
alien_res ~ 1 + (1|ano_flate_id),
data = ANO.mount,
family = ordbeta
)
#| fig-cap: 'Normalisation function (piecewise linear)'
temp <- tibble(
variable = 0:100
)
temp <- temp %>% mutate(indicator = ec_normalise(variable = variable,
x0 = 50,
x60 = 5,
x100 = 0,
fun = "linear")
)
temp |>
ggplot() +
geom_line(aes(x = variable,
y = indicator))
ANO.mount <- ANO.mount %>% mutate(alien_res = ec_normalise(variable = fremmedarter_total_dekning,
x0 = 50,
x60 = 5,
x100 = 0,
fun = "linear")
)
summary(ANO.mount$alien_res)
## Fit ordered beta regression null-model with a random effect
# Norway
alien.no <- glmmTMB(
alien_res ~ 1 + (1|ano_flate_id),
data = ANO.mount,
family = ordbeta
)
summary(alien.no)
# regions
alien.re <- glmmTMB(
alien_res ~ 0 + region + (1|ano_flate_id),
data = ANO.mount,
family = ordbeta
)
summary(alien.re)
NO_ALIE_002 <- tibble(
Region = c("Norway", "Central Norway", "Eastern Norway", "Northern Norway", "Southern Norway", "Western Norway"),
indicator_value = c(plogis(summary(alien.no)$coef$cond[,1]), plogis(summary(alien.re)$coef$cond[,1])),
CI_upper = c(plogis(summary(alien.no)$coef$cond[,1]+1.96*summary(alien.no)$coef$cond[,2]), plogis(summary(alien.re)$coef$cond[,1]+1.96*summary(alien.re)$coef$cond[,2])),
CI_lower = as.numeric(plogis(summary(alien.no)$coef$cond[,1]-1.96*summary(alien.no)$coef$cond[,2]), plogis(summary(alien.re)$coef$cond[,1]-1.96*summary(alien.re)$coef$cond[,2]))
)
NO_ALIE_002
NO_ALIE_002
b0 <- fixef(alien.no)$cond["(Intercept)"]
se_b0 <- sqrt(vcov(alien.no)$cond["(Intercept)", "(Intercept)"])
# Dispersion parameter (For glmmTMB this is usually on the response/positive scale via sigma() )
phi <- sigma(alien.no)
# draw estimates and backtransform from logit-scale
eta_draws <- rnorm(10, mean = b0, sd = se_b0)
mu_draws  <- plogis(eta_draws)
mu_draws
alien_res_sim <- rbeta(
n = 10,
shape1 = mu_draws * phi,
shape2 = (1 - mu_draws) * phi
)
alien_res_sim
b0 <- fixef(alien.no)$cond["(Intercept)"]
